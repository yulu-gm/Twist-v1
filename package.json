{
  "name": "twist-v1",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-first post-apocalyptic colony simulation prototype built with Phaser and TypeScript.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npx vite",
    "build": "tsc --noEmit && npx vite build",
    "build:release": "tsc --noEmit && npx vite build",
    "preview": "npx vite preview",
    "test": "vitest run",
    "test:headless": "vitest run tests/headless/",
    "test:docs": "node tools/aidoc/validate-index.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "happy-dom": "^20.8.9",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.2.4"
  }
}
