{
  "name": "opus-world",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scenario": "vitest run --config vitest.scenario.config.ts",
    "test:scenario:watch": "vitest --config vitest.scenario.config.ts",
    "scenario:visual": "vite --open /scenario.html?scenario=woodcutting",
    "scenario:visual:select": "vite --open /scenario-select.html",
    "generate:module-map": "node tools/generate-project-module-map.mjs",
    "benchmark:search-proj-info:validate": "node tools/benchmark/search_proj_info/validate-benchmark.mjs",
    "benchmark:search-proj-info:scaffold": "node tools/benchmark/search_proj_info/scaffold-run.mjs",
    "benchmark:search-proj-info:report": "node tools/benchmark/search_proj_info/report-benchmark.mjs",
    "benchmark:search-proj-info:run": "node tools/benchmark/search_proj_info/run-corpus-benchmark.mjs"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "preact": "^10.27.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.5.2",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.2",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}
